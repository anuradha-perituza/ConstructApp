# ConstructApp — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
#
# These values are injected into app.json "extra" at build time.
# In development, paste them directly into app.json (see README.md).
# In CI, add them as GitHub Actions repository secrets.

# ─── Anthropic Claude API ────────────────────────────────────────────────────
# Used for AI-powered material extraction from voice transcripts.
# Get your key at: https://console.anthropic.com/settings/keys
# The app works without this key — falls back to local regex extraction.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OpenAI API ──────────────────────────────────────────────────────────────
# Reserved for future Whisper transcription integration.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Android Release Signing (CI only) ───────────────────────────────────────
# Required by GitHub Actions to produce a signed release APK.
# Generate a keystore once with:
#   keytool -genkey -v -keystore release.jks -alias constructapp \
#           -keyalg RSA -keysize 2048 -validity 10000
# Then base64-encode it:
#   base64 -w 0 release.jks   (Linux/macOS)
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("release.jks"))  (PowerShell)
KEYSTORE_BASE64=<base64-encoded-jks-file>
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=constructapp
KEY_PASSWORD=your_key_password

# ─── Expo / EAS ──────────────────────────────────────────────────────────────
# Required by GitHub Actions for EAS cloud builds (optional if using local Gradle build).
# Create a token at: https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_TOKEN=your_expo_access_token
